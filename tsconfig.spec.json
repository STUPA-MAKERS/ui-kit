{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["jest", "node"]
  },
  "include": [
    "src/**/*.spec.ts",
    "markdown-editor/**/*.spec.ts",
    "testing/**/*.ts",
    "setup-jest.ts"
  ]
}
